{
  "name": "@youdotcom-oss/agent-skills",
  "version": "0.0.0",
  "private": true,
  "engines": {
    "node": ">=18",
    "bun": ">= 1.2.21"
  },
  "workspaces": [
    "packges/*"
  ],
  "scripts": {
    "check": "bun run check:js && bun run check:py && bun run check:package && check:types",
    "check:js": "biome check",
    "check:package": "format-package --check",
    "check:py": "uv tool run ruff check .",
    "check:types": "tsc --noEmit",
    "check:write": "bun run check:write-js && bun run check:write-py && bun run check:write-package",
    "check:write-js": "biome check --write",
    "check:write-package": "format-package --write",
    "check:write-py": "uv tool run ruff check --fix . && uv tool run ruff format .",
    "copy:openclaw": "bun scripts/copy-openclaw.ts",
    "eval": "bun scripts/run.ts",
    "eval:summary": "bun scripts/run.ts --summary-only",
    "generate:ydc-schemas": "bun scripts/generate-ydc-schemas.ts",
    "prepare": "git config core.hooksPath .hooks",
    "release:apply": "bun scripts/semver-release.ts apply --plan /tmp/agent-skills-release-plan.json",
    "release:dry-run": "bun scripts/semver-release.ts plan --base HEAD~1 --out /tmp/agent-skills-release-plan.json",
    "release:plan": "bun scripts/semver-release.ts plan"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "biome check --write --no-errors-on-unmatched"
    ],
    "*.{json,md}": [
      "biome format --write --no-errors-on-unmatched"
    ],
    "*.py": [
      "uv tool run ruff check --fix",
      "uv tool run ruff format"
    ],
    "package.json": [
      "format-package --write"
    ]
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.0",
    "@ai-sdk/mcp": "^2.0.0",
    "@langchain/anthropic": "^1.3.28",
    "@langchain/core": "^1.1.42",
    "@youdotcom-oss/ai-sdk-plugin": "^2.2.3",
    "@youdotcom-oss/api": "^0.5.2",
    "@youdotcom-oss/langchain": "^1.2.2",
    "ai": "^7.0.0",
    "langchain": "^1.3.5"
  },
  "devDependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.126",
    "@anthropic-ai/sdk": "^0.92.0",
    "@biomejs/biome": "2.4.14",
    "@commitlint/cli": "^20.5.3",
    "@commitlint/config-conventional": "^20.5.3",
    "@microsoft/teams.ai": "^2.0.9",
    "@microsoft/teams.apps": "^2.0.9",
    "@microsoft/teams.common": "^2.0.9",
    "@microsoft/teams.mcpclient": "^2.0.9",
    "@openai/agents": "^0.8.5",
    "@opencode-ai/plugin": "^1.18.2",
    "@plaited/agent-eval-harness": "^0.13.0",
    "@plaited/development-skills": "^0.8.1",
    "@types/bun": "1.3.13",
    "@youdotcom-oss/teams-anthropic": "^1.1.1",
    "format-package": "^7.0.0",
    "lint-staged": "^16.4.0",
    "typescript": "^6.0.3",
    "typescript-language-server": "^5.1.3",
    "zod": "^4.4.1"
  }
}
