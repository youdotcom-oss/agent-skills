{
  "name": "@youdotcom-oss/agent-skills",
  "private": true,
  "engines": {
    "node": ">=18",
    "bun": ">= 1.2.21"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "bun run --filter '*' build",
    "check": "bun run check:ts && bun run check:py && bun run check:package && bun run check:types",
    "check:package": "format-package --check",
    "check:py": "bun run --cwd packages/hermes check:python",
    "check:ts": "biome check",
    "check:types": "tsc --noEmit",
    "check:write": "bun run check:write-js && bun run check:write-py && bun run check:write-package",
    "check:write-js": "biome check --write",
    "check:write-package": "format-package --write",
    "check:write-py": "uv tool run ruff check --fix packages/hermes && uv tool run ruff format packages/hermes",
    "prepare": "git config core.hooksPath .hooks",
    "release:apply": "bun scripts/semver-release.ts apply --plan /tmp/agent-skills-release-plan.json",
    "release:dry-run": "bun scripts/semver-release.ts plan --base HEAD~1 --out /tmp/agent-skills-release-plan.json",
    "release:plan": "bun scripts/semver-release.ts plan",
    "test": "bun test && bun run --cwd packages/hermes test:python",
    "validate:skills": "bun test tests/validate-skills.spec.ts"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "biome check --write --no-errors-on-unmatched"
    ],
    "*.{json,md}": [
      "biome format --write --no-errors-on-unmatched"
    ],
    "*.py": [
      "uv tool run ruff check --fix",
      "uv tool run ruff format"
    ],
    "package.json": [
      "format-package --write"
    ]
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.5",
    "@commitlint/cli": "^21.2.1",
    "@commitlint/config-conventional": "^21.2.0",
    "@types/bun": "1.3.14",
    "format-package": "^8.0.0",
    "lint-staged": "^17.1.1",
    "typescript": "^7.0.2"
  }
}
